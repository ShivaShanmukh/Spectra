# ─── Supabase ─────────────────────────────────────────────────────────────────
# Use the SERVICE ROLE key — this service bypasses RLS to write deliveries
# and analytics on behalf of any user. Never expose this key to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your Next.js app origin. In production, set this to your deployed URL.
# e.g. https://crickettrack.vercel.app
ALLOWED_ORIGIN=http://localhost:3000
